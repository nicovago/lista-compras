rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedFamilyMember() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "REEMPLAZAR_CON_EMAIL_DE_NICO",
          "REEMPLAZAR_CON_EMAIL_DE_LAURA"
        ];
    }

    match /lists/main/items/{itemId} {
      allow read, create, update, delete: if isAuthorizedFamilyMember();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
